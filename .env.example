# HubSpot Private App token for Hub ID 20300238
# Create at: HubSpot → Settings → Integrations → Private Apps
HUBSPOT_API_KEY=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Gmail address used to send the report
GMAIL_SENDER=your-sender@gmail.com

# Gmail App Password (NOT your account password)
# Create at: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Comma-separated list of recipient email addresses
REPORT_RECIPIENTS=recipient1@example.com,recipient2@example.com
